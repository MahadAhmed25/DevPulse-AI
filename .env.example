# =============================================================================
# DevPulse AI — Environment Variables
# Copy to .env and fill in all values before running locally.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=devpulse-diffs

# Amazon Bedrock — Titan Embeddings V2
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# -----------------------------------------------------------------------------
# Database (RDS PostgreSQL in prod, local postgres in dev)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://devpulse:devpulse@localhost:5432/devpulse

# -----------------------------------------------------------------------------
# Redis (ElastiCache in prod, local redis in dev)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# GitHub OAuth & Webhooks
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Auth (JWT)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# 7 days in minutes
JWT_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
